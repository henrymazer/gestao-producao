@page
@model IndexModel
@{
    ViewData["Title"] = "Início";
}

@if (User.Identity?.IsAuthenticated ?? false)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <h1 class="h3 mb-3">Sistema de Gestão de Produção</h1>
            <p class="text-muted mb-4">Base da Fase 1 concluída: autenticação, banco de dados e estrutura de módulos.</p>

            <div class="row g-3">
                <div class="col-md-6 col-xl-4">
                    <a class="d-block p-3 bg-light rounded border text-decoration-none text-body" asp-page="/Producao/Index">
                        Planejamento de Produção
                    </a>
                </div>
                <div class="col-md-6 col-xl-4">
                    <a class="d-block p-3 bg-light rounded border text-decoration-none text-body" asp-page="/Estoque/Index">
                        Gestão de Estoque
                    </a>
                </div>
                <div class="col-md-6 col-xl-4">
                    <a class="d-block p-3 bg-light rounded border text-decoration-none text-body" asp-page="/Insumos/Rastreabilidade">
                        Rastreamento de Insumos
                    </a>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4 text-center">
            <h1 class="h4 mb-3">Acesso restrito</h1>
            <p class="text-muted mb-0">Use a opção <strong>Entrar</strong> no topo da página para acessar o sistema.</p>
        </div>
    </div>
}
