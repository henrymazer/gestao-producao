@page
@{
    ViewData["Title"] = "Cadastros Base";
}

<div class="mb-3">
    <h1 class="h4 mb-1">Cadastros Base</h1>
    <p class="text-muted mb-0">Gerencie os dados fundamentais usados pelos módulos de produção e estoque.</p>
</div>

<div class="row g-3">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h2 class="h6">Produtos</h2>
                <p class="text-muted small flex-grow-1">Cadastro de itens acabados com unidade e preço de venda.</p>
                <a asp-page="/Produtos/Index" class="btn btn-outline-primary btn-sm">Acessar</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-4">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h2 class="h6">Equipamentos</h2>
                <p class="text-muted small flex-grow-1">Capacidade produtiva, disponibilidade e status operacional.</p>
                <a asp-page="/Equipamentos/Index" class="btn btn-outline-primary btn-sm">Acessar</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-4">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h2 class="h6">Funcionários</h2>
                <p class="text-muted small flex-grow-1">Controle da equipe e disponibilidade para execução.</p>
                <a asp-page="/Funcionarios/Index" class="btn btn-outline-primary btn-sm">Acessar</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-4">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h2 class="h6">Composição de Produto (BOM)</h2>
                <p class="text-muted small flex-grow-1">Definição de insumos necessários por produto final.</p>
                <a asp-page="/Cadastros/Bom" class="btn btn-outline-primary btn-sm">Acessar</a>
            </div>
        </div>
    </div>
</div>
