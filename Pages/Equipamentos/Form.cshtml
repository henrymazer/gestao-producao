@page "{id:int?}"
@using gestao_producao.Models.Enums
@model gestao_producao.Pages.Equipamentos.FormModel
@{
    ViewData["Title"] = Model.EhEdicao ? "Editar Equipamento" : "Novo Equipamento";
}

<div class="mb-3">
    <h1 class="h4 mb-1">@ViewData["Title"]</h1>
    <p class="text-muted mb-0">Informe os dados do equipamento de produção.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Equipamento.Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Equipamento.Nome" class="form-label"></label>
                    <input asp-for="Equipamento.Nome" class="form-control" />
                    <span asp-validation-for="Equipamento.Nome" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Equipamento.CapacidadePorHora" class="form-label"></label>
                    <input asp-for="Equipamento.CapacidadePorHora" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Equipamento.CapacidadePorHora" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Equipamento.Status" class="form-label"></label>
                    <select asp-for="Equipamento.Status" class="form-select" asp-items="Model.StatusOptions"></select>
                    <span asp-validation-for="Equipamento.Status" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Equipamento.Descricao" class="form-label"></label>
                    <input asp-for="Equipamento.Descricao" class="form-control" />
                    <span asp-validation-for="Equipamento.Descricao" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="Equipamento.Ativo" class="form-check-input" />
                        <label asp-for="Equipamento.Ativo" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Salvar</button>
                <a asp-page="/Equipamentos/Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
