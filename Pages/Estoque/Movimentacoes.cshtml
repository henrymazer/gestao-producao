@page
@using gestao_producao.Models.Enums
@model gestao_producao.Pages.Estoque.MovimentacoesModel
@{
    ViewData["Title"] = "Histórico de Movimentações";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="h4 mb-1">Histórico de movimentações</h1>
        <p class="text-muted mb-0">Rastreabilidade completa de entradas, saídas e ajustes de inventário.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="/Estoque/Movimentar" class="btn btn-primary">Nova movimentação</a>
        <a asp-page="/Estoque/Index" class="btn btn-outline-secondary">Voltar ao estoque</a>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-12 col-md-4">
                <label asp-for="TipoMovimentacao" class="form-label">Tipo</label>
                <select asp-for="TipoMovimentacao" class="form-select" asp-items="Html.GetEnumSelectList<TipoMovimentacao>()">
                    <option value="">Todos</option>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label asp-for="Inicio" class="form-label">Data inicial</label>
                <input asp-for="Inicio" type="date" class="form-control" />
            </div>
            <div class="col-12 col-md-3">
                <label asp-for="Fim" class="form-label">Data final</label>
                <input asp-for="Fim" type="date" class="form-control" />
            </div>
            <div class="col-12 col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white">
        <h2 class="h6 mb-0">Registros (@Model.Movimentacoes.Count)</h2>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Data</th>
                        <th>Item</th>
                        <th>Tipo</th>
                        <th>Quantidade</th>
                        <th>Motivo</th>
                        <th>Documento</th>
                        <th>Usuário</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Movimentacoes.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">Nenhuma movimentação encontrada.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Movimentacoes)
                    {
                        <tr>
                            <td>@item.DataMovimentacao.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.NomeItem</td>
                            <td>@item.TipoMovimentacao</td>
                            <td>@item.Quantidade.ToString("N2")</td>
                            <td>@item.Motivo</td>
                            <td>@(string.IsNullOrWhiteSpace(item.DocumentoReferencia) ? "-" : item.DocumentoReferencia)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.UsuarioId) ? "-" : item.UsuarioId)</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
