@page
@using gestao_producao.Models.Enums
@using gestao_producao.Services
@model gestao_producao.Pages.Estoque.MovimentarModel
@{
    ViewData["Title"] = "Movimentar Estoque";
    var isEntrada = Model.Input.TipoMovimentacao == TipoMovimentacao.Entrada;
    var isAjuste = Model.Input.TipoMovimentacao == TipoMovimentacao.Ajuste;
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="h4 mb-1">Registrar movimentação</h1>
        <p class="text-muted mb-0">Entradas, saídas e ajustes manuais com rastreabilidade completa.</p>
    </div>
    <a asp-page="/Estoque/Index" class="btn btn-outline-secondary">Voltar ao estoque</a>
</div>

<partial name="_StatusMessages" model="Model" />

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" class="row g-3">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="col-12 col-md-4">
                <label asp-for="Input.TipoMovimentacao" class="form-label">Tipo de movimentação</label>
                <select asp-for="Input.TipoMovimentacao" class="form-select" asp-items="Html.GetEnumSelectList<TipoMovimentacao>()"></select>
            </div>

            @if (!isEntrada)
            {
                <div class="col-12 col-md-8">
                    <label asp-for="Input.EstoqueId" class="form-label">Item de estoque</label>
                    <select asp-for="Input.EstoqueId" class="form-select" asp-items="Model.EstoquesOptions">
                        <option value="">Selecione um item</option>
                    </select>
                    <span asp-validation-for="Input.EstoqueId" class="text-danger"></span>
                </div>
            }

            @if (isEntrada)
            {
                <div class="col-12 col-md-4">
                    <label asp-for="Input.TipoItem" class="form-label">Tipo do item</label>
                    <select asp-for="Input.TipoItem" class="form-select" asp-items="Html.GetEnumSelectList<TipoItem>()">
                        <option value="">Selecione</option>
                    </select>
                    <span asp-validation-for="Input.TipoItem" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="Input.InsumoId" class="form-label">Insumo</label>
                    <select asp-for="Input.InsumoId" class="form-select" asp-items="Model.InsumosOptions">
                        <option value="">Selecione (para matéria-prima)</option>
                    </select>
                    <span asp-validation-for="Input.InsumoId" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="Input.ProdutoId" class="form-label">Produto</label>
                    <select asp-for="Input.ProdutoId" class="form-select" asp-items="Model.ProdutosOptions">
                        <option value="">Selecione (para em processo/acabado)</option>
                    </select>
                    <span asp-validation-for="Input.ProdutoId" class="text-danger"></span>
                </div>
            }

            <div class="col-12 col-md-3">
                <label asp-for="Input.Quantidade" class="form-label">Quantidade</label>
                <input asp-for="Input.Quantidade" class="form-control" />
                <span asp-validation-for="Input.Quantidade" class="text-danger"></span>
            </div>

            @if (isAjuste)
            {
                <div class="col-12 col-md-3">
                    <label asp-for="Input.TipoAjuste" class="form-label">Modo do ajuste</label>
                    <select asp-for="Input.TipoAjuste" class="form-select" asp-items="Html.GetEnumSelectList<TipoAjusteEstoque>()"></select>
                </div>
            }

            <div class="col-12 col-md-6">
                <label asp-for="Input.Motivo" class="form-label">Motivo</label>
                <input asp-for="Input.Motivo" class="form-control" placeholder="Ex.: Compra, consumo em produção, correção de inventário" />
                <span asp-validation-for="Input.Motivo" class="text-danger"></span>
            </div>

            <div class="col-12 col-md-4">
                <label asp-for="Input.DocumentoReferencia" class="form-label">Documento de referência</label>
                <input asp-for="Input.DocumentoReferencia" class="form-control" placeholder="NF, OP, etc." />
                <span asp-validation-for="Input.DocumentoReferencia" class="text-danger"></span>
            </div>

            <div class="col-12 col-md-4">
                <label asp-for="Input.Lote" class="form-label">Lote</label>
                <input asp-for="Input.Lote" class="form-control" />
                <span asp-validation-for="Input.Lote" class="text-danger"></span>
            </div>

            <div class="col-12 col-md-4">
                <label asp-for="Input.Localizacao" class="form-label">Localização</label>
                <input asp-for="Input.Localizacao" class="form-control" placeholder="Depósito/Prateleira" />
                <span asp-validation-for="Input.Localizacao" class="text-danger"></span>
            </div>

            <div class="col-12 col-md-4">
                <label asp-for="Input.DataValidade" class="form-label">Data de validade</label>
                <input asp-for="Input.DataValidade" class="form-control" type="date" />
            </div>

            <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                <a asp-page="/Estoque/Index" class="btn btn-outline-secondary">Cancelar</a>
                <button type="submit" class="btn btn-primary">Salvar movimentação</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
