<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestão de Produção</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/gestao_producao.styles.css" asp-append-version="true" />
</head>
<body class="bg-light">
    @{
        var usuarioAutenticado = User.Identity?.IsAuthenticated ?? false;
    }

    @if (usuarioAutenticado)
    {
        <div class="container-fluid min-vh-100">
            <div class="row">
                <aside class="col-12 col-lg-3 col-xl-2 bg-dark text-white p-3">
                    <a class="navbar-brand text-white fw-semibold d-block mb-3" asp-area="" asp-page="/Index">Gestão de Produção</a>

                    <div class="small text-uppercase text-secondary mb-2">Módulos</div>
                    <nav class="nav flex-column gap-1">
                        <a class="nav-link text-white p-0" asp-page="/Producao/Index">Produção</a>
                        <a class="nav-link text-white-50 p-0 ps-2" asp-page="/Producao/Planos/Index">Planos de Produção</a>
                        <a class="nav-link text-white-50 p-0 ps-2" asp-page="/Producao/Ordens/Index">Ordens de Produção</a>
                        <a class="nav-link text-white-50 p-0 ps-2" asp-page="/Producao/Timeline">Timeline</a>
                        <a class="nav-link text-white p-0" asp-page="/Estoque/Index">Estoque</a>
                        <a class="nav-link text-white p-0" asp-page="/Insumos/Index">Insumos</a>
                        <a class="nav-link text-white-50 p-0 ps-2" asp-page="/Insumos/Rastreabilidade">Rastreabilidade de Insumos</a>
                        <a class="nav-link text-white p-0" asp-page="/Fornecedores/Index">Fornecedores</a>
                        <a class="nav-link text-white p-0" asp-page="/Cadastros/Bom">Composição (BOM)</a>
                        <a class="nav-link text-white p-0" asp-page="/Cadastros/Index">Cadastros Base</a>
                        <a class="nav-link text-white p-0" asp-page="/Relatorios/Index">Relatórios</a>
                    </nav>
                </aside>

                <div class="col-12 col-lg-9 col-xl-10 p-0">
                    <header>
                        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom px-3">
                            <div class="container-fluid px-0">
                                <span class="navbar-text text-muted">Sistema de Planejamento e Controle</span>
                                <partial name="_LoginPartial" />
                            </div>
                        </nav>
                    </header>

                    <main role="main" class="p-3">
                        @RenderBody()
                    </main>
                </div>
            </div>
        </div>
    }
    else
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom px-3">
                <div class="container-fluid px-0">
                    <a class="navbar-brand mb-0 h1" asp-area="" asp-page="/Index">Gestão de Produção</a>
                    <partial name="_LoginPartial" />
                </div>
            </nav>
        </header>

        <main role="main" class="container py-4">
            @RenderBody()
        </main>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
