@page
@model gestao_producao.Pages.Fornecedores.IndexModel
@{
    ViewData["Title"] = "Fornecedores";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="h4 mb-1">Fornecedores</h1>
        <p class="text-muted mb-0">Cadastro e manutenção dos fornecedores da fábrica.</p>
    </div>
    <a asp-page="/Fornecedores/Form" class="btn btn-primary">Novo fornecedor</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.MensagemSucesso))
{
    <div class="alert alert-success">@Model.MensagemSucesso</div>
}

@if (!string.IsNullOrWhiteSpace(Model.MensagemErro))
{
    <div class="alert alert-danger">@Model.MensagemErro</div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>CNPJ</th>
                        <th>Contato</th>
                        <th>Status</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Fornecedores.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Nenhum fornecedor cadastrado.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Fornecedores)
                    {
                        <tr>
                            <td>@item.Nome</td>
                            <td>@item.Cnpj</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Contato) ? "-" : item.Contato)</td>
                            <td>
                                <span class="badge @(item.Ativo ? "bg-success" : "bg-secondary")">
                                    @(item.Ativo ? "Ativo" : "Inativo")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-2">
                                    <a asp-page="/Fornecedores/Form" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Confirma exclusão do fornecedor?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Excluir</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
